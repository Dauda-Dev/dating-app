# Database Configuration
DB_NAME=dating_app
DB_USER=dating_user
DB_PASSWORD=secure_password_change_me
DB_HOST=postgres
DB_PORT=5432
DB_DIALECT=postgres

# JWT Configuration
JWT_SECRET=change_me
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY_DAYS=30
SESSION_SECRET=change_me_session_secret

# Server Configuration
PORT=3000
NODE_ENV=development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=mock_google_client_id
GOOGLE_CLIENT_SECRET=mock_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Mailgun Configuration
MAILGUN_API_KEY=mock_mailgun_api_key
MAILGUN_DOMAIN=mg.example.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAIL_FROM=no-reply@example.com

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
PAYSTACK_BASE_URL=https://api.paystack.co

# Store Subscriptions Configuration
SUBSCRIPTION_PROVIDER=store
GOOGLE_PLAY_PREMIUM_PRODUCT_ID=ovally_premium_monthly
GOOGLE_PLAY_GOLD_PRODUCT_ID=ovally_gold_monthly
GOOGLE_PLAY_PACKAGE_NAME=com.ovally.app
APPLE_PREMIUM_PRODUCT_ID=ovally.premium.monthly
APPLE_GOLD_PRODUCT_ID=ovally.gold.monthly
APPLE_BUNDLE_ID=com.ovally.app
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
APPLE_USE_SANDBOX=true

# Firebase Push (FCM)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FCM_SERVER_KEY=

# Mobile Ads (used by dating-app-mobile)
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
AD_SWIPE_INTERSTITIAL_ENABLED=true
AD_SWIPE_INTERSTITIAL_EVERY_N=8
AD_SWIPE_INTERSTITIAL_DAILY_CAP=15

# Video Calling (Daily.co)
DAILY_API_KEY=mock_daily_key
DAILY_BASE_URL=https://api.daily.co/v1

# Redis Configuration
REDIS_URL=redis://redis:6379

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# App Configuration
APP_NAME=DatingApp
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:19006

# Subscription Limits (Free Tier)
FREE_TIER_MAX_MATCHES_PER_WEEK=5
FREE_TIER_MAX_STEALS_PER_WEEK=2
FREE_TIER_MAX_DISCOVERIES_PER_DAY=20

# Video Call Configuration
VIDEO_CALL_MIN_DURATION=240
VIDEO_CALL_MAX_DURATION=600

FRONTEND_URL=http://localhost:19006
